# Copy to infrastructure/pi/.env on tower before bringing up the pi lane.

# Match the tower user so files created in the bind-mounted repo are not root-owned.
PI_RUNTIME_UID=1000
PI_RUNTIME_GID=1000

# Compose external network created by the base Medplum stack.
MEDPLUM_DOCKER_NETWORK=infrastructure_default
MEDPLUM_DOCKER_BASE_URL=http://medplum-server:8103

# Medplum machine auth for the lane.
FHIR_SERVER=http://medplum-server:8103/fhir/R4
FHIR_BASE_URL=http://medplum-server:8103/fhir/R4
FHIR_TOKEN_ENDPOINT=http://medplum-server:8103/oauth2/token
FHIR_CLIENT_ID=
FHIR_CLIENT_SECRET=

# pi.dev model provider config.
PI_PROVIDER=openai
PI_MODEL=
PI_OFFLINE=0
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
